# Copy to .env.local (gitignored) for local development against a cloud project,
# or leave unset entirely to fall back to the values baked into src/lib/supabase.ts.
#
# Local Dev via Supabase CLI instead needs no env vars at all — `supabase start`
# prints its own local URL/anon key, which the CLI's own .env handling picks up.
#
# These are publishable/anon keys — safe to expose client-side, not secrets.

# Staging project (vasto-arch-crm-staging)
VITE_SUPABASE_URL=https://uxmkieetbzegunhakcxk.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_qWUQMnSwxdte23EfFg72Ag_gJoLkzWS

# Production project (vasto-arch-crm) — this is also the hardcoded fallback
# in src/lib/supabase.ts, so Production works even with no env vars set.
# VITE_SUPABASE_URL=https://weckowkvqpamnlcqwvfh.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_LapPa0d0ihwF9Uic_cz0zA_mgDTbI6W
